# ─────────────────────────────────────────────────────────────────────────────
# Production environment template.
#
# Copy to `.env` on the deployment host (or, preferably, inject these values from your
# orchestrator's secret store — Docker/Swarm secrets, Kubernetes Secrets, a cloud secrets
# manager — rather than committing a file). `.env` is git-ignored and passed in at runtime;
# it is never baked into the image.
#
# Deploy with the production compose override:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# App
# production makes SMTP_USER/SMTP_PASSWORD REQUIRED
# (docker-compose.prod.yml also forces NODE_ENV=production for the app container.)
NODE_ENV=production
HTTP_PORT=3000

# Database — use strong, unique credentials (not the postgres/postgres dev defaults).
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME_STRONG_SECRET
POSTGRES_DB=email_sender
# In the compose network the DB host is the service name `postgres`, not localhost.
# docker-compose.yml already sets this for the app/migrate containers; keep it consistent here.
DATABASE_URL=postgres://CHANGE_ME:CHANGE_ME_STRONG_SECRET@postgres:5432/email_sender

# RabbitMQ — replace the guest/guest defaults; guest cannot authenticate over a network in prod.
RABBITMQ_USER=CHANGE_ME
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_SECRET
RABBITMQ_URL=amqp://CHANGE_ME:CHANGE_ME_STRONG_SECRET@rabbitmq:5672
SENDER_RABBIT_EXCHANGE_NAME=google_email_sender
SENDER_RABBIT_QUEUE_NAME=google_email_sender_queue
SENDER_RABBIT_QUEUE_ROUTING_KEY=email_sender
# Max unacknowledged messages the consumer holds in flight (RMQ prefetch / QoS).
RABBIT_PREFETCH=10

# Email behavior
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_DELAY_SECONDS=60
EMAIL_RETRY_MAX_DELAY_SECONDS=3600
EMAIL_SUCCESS_RETENTION_DAYS=30
EMAIL_CLEANUP_BATCH_SIZE=500

# Worker
WORKER_POLL_INTERVAL_MS=5000
WORKER_CLAIM_BATCH_SIZE=20
# true = this node also sends; set false for ingest-only nodes with a separate worker pool.
WORKER_ENABLED=true

# SMTP — REQUIRED in production. Gmail SMTP + App Password by default (any SMTP server works).
# For Gmail: enable 2-Step Verification, then create a 16-char App Password
# (https://myaccount.google.com/apppasswords). SMTP_USER is the full address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=CHANGE_ME@example.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
# Optional: defaults to SMTP_USER. For Gmail it must be the account address or a verified alias.
SMTP_FROM=
