# App
# NODE_ENV=production makes SMTP_USER/SMTP_PASSWORD below REQUIRED — the app fails fast without them.
NODE_ENV=development
HTTP_PORT=3000

# Database (matches docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_sender
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/email_sender
# When the SERVICE itself runs in docker compose, hosts are service names, not localhost.
# docker-compose.yml already overrides these two for the app/migrate containers, so you
# normally leave the localhost values here for host-run (pnpm start:dev / migrations).
#   DATABASE_URL=postgres://postgres:postgres@postgres:5432/email_sender
#   RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@localhost:5672
SENDER_RABBIT_EXCHANGE_NAME=google_email_sender
SENDER_RABBIT_QUEUE_NAME=google_email_sender_queue
SENDER_RABBIT_QUEUE_ROUTING_KEY=email_sender
# Max unacknowledged messages the consumer holds in flight (RMQ prefetch / QoS).
RABBIT_PREFETCH=10

# Email behavior
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_DELAY_SECONDS=60
EMAIL_RETRY_MAX_DELAY_SECONDS=3600
EMAIL_SUCCESS_RETENTION_DAYS=30
EMAIL_CLEANUP_BATCH_SIZE=500

# Worker
WORKER_POLL_INTERVAL_MS=5000
WORKER_CLAIM_BATCH_SIZE=20
# Set to false to disable the in-process worker (e.g. when running workers separately)
WORKER_ENABLED=true

# SMTP (Gmail SMTP + App Password)
# For Gmail: enable 2-Step Verification, then create a 16-char App Password
# (https://myaccount.google.com/apppasswords). SMTP_USER is the full Gmail address, SMTP_PASSWORD
# is the App Password. No Google Cloud project, OAuth consent screen, or refresh token needed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=me@gmail.com
SMTP_PASSWORD=
# Optional: defaults to SMTP_USER. For Gmail it must be the account address or a verified alias.
SMTP_FROM=
