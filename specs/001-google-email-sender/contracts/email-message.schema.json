{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://innoway.es/contracts/google-email-sender/email-message.schema.json",
  "title": "EmailMessage",
  "description": "Payload published by a tenant Outbox to the google_email_sender exchange with routing key email_sender. Consumed by the google-email-sender microservice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenantId",
    "tenantName",
    "appName",
    "messageId",
    "recipient",
    "subject",
    "body"
  ],
  "properties": {
    "tenantId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier of the tenant. Part of the dedupe key."
    },
    "tenantName": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable tenant name (audit only)."
    },
    "appName": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the producing application (audit only)."
    },
    "messageId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Globally stable id generated by the producer's Outbox. Unique per tenant. THE dedupe key — redeliveries reuse the same value."
    },
    "recipient": {
      "type": "string",
      "format": "email",
      "description": "Destination email address."
    },
    "subject": {
      "type": "string",
      "description": "Email subject line."
    },
    "body": {
      "type": "string",
      "description": "Email body (plain text or HTML)."
    }
  },
  "examples": [
    {
      "tenantId": "11111111-2222-3333-4444-555555555555",
      "tenantName": "Acme Corp",
      "appName": "billing-api",
      "messageId": "billing-api:invoice-2026-0001",
      "recipient": "customer@example.com",
      "subject": "Your invoice is ready",
      "body": "<p>Invoice #2026-0001 attached.</p>"
    }
  ]
}
